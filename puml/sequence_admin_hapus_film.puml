@startuml
skinparam style strictuml
skinparam sequence {
    ArrowColor #2C3E50
    LifeLineBorderColor #2C3E50
    LifeLineBackgroundColor #ECF0F1
}

actor "Admin" as admin
participant "View\n(Admin Panel)" as view
participant "FilmController" as controller
participant "Model\nFilm" as model
database "Database" as db

admin -> view : Klik tombol "Hapus" pada suatu film
activate view

view -> controller : DELETE /films/{id}
activate controller

controller -> model : Temukan film berdasarkan ID & Hapus
activate model

model -> db : DELETE FROM film WHERE id = {id}
activate db
db --> model : Success
deactivate db

model --> controller : Film terhapus
deactivate model

controller --> view : Redirect ke Dashboard Admin + Pesan Sukses
deactivate controller

view --> admin : Tabel film diperbarui (film hilang dari daftar)
deactivate view
@enduml
